# Fonts
font-size = 14
font-feature = -calt

# Theme
theme = "Gruvbox Dark"

# Cursor
cursor-style = block
cursor-click-to-move = true
cursor-style-blink = false
mouse-hide-while-typing = true

# Shell
shell-integration = fish
shell-integration-features = no-cursor,sudo,title

# Keybindings
keybind = global:cmd+shift+space=toggle_quick_terminal
keybind = cmd+r=reload_config
keybind = cmd+p=toggle_command_palette
keybind = cmd+s=new_split:right
keybind = cmd+shift+s=new_split:down
keybind = cmd+shift+l=goto_split:right
keybind = cmd+shift+h=goto_split:left
keybind = cmd+shift+k=goto_split:up
keybind = cmd+shift+j=goto_split:down
keybind = cmd+shift+m=toggle_split_zoom

# Others
confirm-close-surface = false
quick-terminal-autohide = true
clipboard-paste-protection = false
